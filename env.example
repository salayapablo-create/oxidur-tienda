# ============================================================
# Variables de entorno OXIDUR
# ============================================================
# Copiá este archivo como .env y completá los valores reales.
# El archivo .env NUNCA se sube a Git ni a Netlify.
# En Render, estas variables se cargan en Settings → Environment.
# ============================================================

# MercadoPago (panel: https://www.mercadopago.com.ar/developers/panel)
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxx-xxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-xxxxxxxxx

# Envia.com (panel: https://envia.com → Configuración → API)
ENVIA_API_KEY=tu_api_key_de_envia_aqui

# Modo Envia: "test" para probar sin generar guías reales / "production" para real
ENVIA_MODE=production

# URL pública del sitio
SITE_URL=https://tiendaoxidur.com

# ============================================================
# EMAILS (Resend) — opcional pero recomendado
# ============================================================
# Conseguí tu API Key gratis en https://resend.com/api-keys
# Plan gratis: 3000 emails/mes
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxx

# Mail "de" que aparece como remitente. Mientras no configures dominio propio
# dejá el default de Resend. Cuando verifiques tu dominio podés usar:
# EMAIL_FROM=OXIDUR <ventas@tiendaoxidur.com>
EMAIL_FROM=OXIDUR <onboarding@resend.dev>

# Mails del admin (separados por coma sin espacios)
# Ejemplo: ADMIN_EMAILS=microfloor1@hotmail.com,otro@hidrosol.com.ar
ADMIN_EMAILS=microfloor1@hotmail.com

# Email de notificaciones default (si ADMIN_EMAILS no está)
NOTIFY_EMAIL=microfloor1@hotmail.com

# WhatsApp para mostrar en el mail al cliente (sin +, ni espacios)
WHATSAPP_NUMBER=5491158533291

# Puerto (Render lo asigna automáticamente)
PORT=3000
